{
  "rules": {
    "name": "default",
    "children": [],
    "behaviors": [
      {
        "name": "origin",
        "options": {
          "originType": "CUSTOMER",
          "hostname": "origin-beacon.connected-cloud.io",
          "httpPort": 80,
          "httpsPort": 443,
          "forwardHostHeader": "REQUEST_HOST_HEADER",
          "cacheKeyHostname": "REQUEST_HOST_HEADER",
          "compress": false,
          "enableTrueClientIp": false,
          "originSni": true,
          "verificationMode": "PLATFORM_SETTINGS",
          "minTlsVersion": "DYNAMIC",
          "ipVersion": "IPV4"
        }
      },
      {
        "name": "cpCode",
        "options": {
          "value": {
            "id": ${cpcode_id}
          }
        }
      },
      {
        "name": "caching",
        "options": {
          "behavior": "NO_STORE"
        }
      },
      {
        "name": "constructResponse",
        "options": {
          "enabled": true,
          "responseCode": 200,
          "body": "ok",
          "forceEviction": false
        }
      },
      {
        "name": "http2",
        "options": {}
      }
%{ if ds2_stream_id != 0 ~}
      ,{
        "name": "datastream",
        "options": {
          "enabled": true,
          "streamType": "LOG",
          "logEnabled": true,
          "logStreamName": ["${ds2_stream_id}"],
          "datastreamIds": "${ds2_stream_id}"
        }
      }
%{ endif ~}
    ],
    "options": {
      "is_secure": false
    }
  }
}
